# Postgres — deal-flow-matchmaker credentials (compose defaults match these).
DB_NAME=dealflow
DB_USER=dealflow
DB_PASSWORD=dealflow
# Host port for postgres. 5433 because deal-flow-matchmaker-postgres-1 holds 5432.
DB_PORT=5433

JWT_SECRET=change-me-in-a-real-environment

# Empty → extract agent falls back to deterministic feature-hash embeddings.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://mkp-api.fptcloud.com
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Host ports. Defaults clash with the host-run dev services (gateway :3000,
# uvicorn :8000, vite :5173) — stop those first, or override these.
GATEWAY_PORT=3000
MATCHING_PORT=3002
EXTRACT_PORT=3003
MATCHING_API_PORT=8000
# Frontend (nginx serving the Vite build + /api proxy).
WEB_PORT=5173
